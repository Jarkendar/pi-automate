    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"status\": {\n      \"type\": \"string\",\n      \"enum\": [\"accepted\", \"rejected\"],\n      \"description\": \"Classification status: 'accepted' for projects and actionable tasks, 'rejected' for shopping lists, gibberish, or overly short notes.\"\n    },\n    \"goal\": {\n      \"type\": \"string\",\n      \"description\": \"A concise, technical summary of the main objective.\"\n    },\n    \"action_plan\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      },\n      \"description\": \"A list of specific steps to be taken, each including a time estimate, e.g., 'Configure Docker Compose (~20 min)'.\"\n    },\n    \"total_estimated_time\": {\n      \"type\": \"string\",\n      \"description\": \"A realistic total sum of time required for the entire plan (e.g., '~2h 15min').\"\n    },\n    \"engineer_comment\": {\n      \"type\": \"string\",\n      \"description\": \"A short, professional engineering insight or a motivational tip.\"\n    }\n  },\n  \"required\": [\"status\", \"goal\", \"action_plan\", \"total_estimated_time\", \"engineer_comment\"]\n}"
      },
