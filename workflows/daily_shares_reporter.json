    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  let rawText = \"\";\n  if (item.json.text) {\n    rawText = item.json.text;\n  } else if (item.json.content && item.json.content.parts && item.json.content.parts[0].text) {\n    rawText = item.json.content.parts[0].text;\n  }\n\n  const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n  \n  let importance = 0;\n  let description = \"Error: JSON not found\";\n  let symbol = \"UNKNOWN\";\n\n  if (jsonMatch) {\n    try {\n      const parsed = JSON.parse(jsonMatch[0]);\n      importance = parsed.importance ?? 0;\n      description = parsed.description ?? \"No description\";\n      symbol = parsed.Symbol ?? \"UNKNOWN\";\n    } catch (e) {\n      description = \"Parse Error: \" + e.message;\n    }\n  }\n\n  return {\n    json: {\n      Symbol: symbol,\n      importance,\n      description\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        1232
      ],
      "id": "7090f581-1cfe-4dbb-b826-184e1a512c5c",
      "name": "Parse respond"
    },
    {
      "parameters": {
        "jsCode": "// Get the full list of AI responses from the previous node\nconst aiResults = $input.all();\n\n// Get the full list of stock data (make sure the node name is correct!)\nconst stockDataList = $('Count data').all();\n\nconst now = new Date();\nconst formattedDate = now.toISOString().replace('T', ' ').substring(0, 16);\n\nlet finalResults = [];\n\n// Iterate through each AI result\nfor (const aiItem of aiResults) {\n  const aiSymbol = aiItem.json.Symbol;\n  \n  // SEARCH: Find the object in stock data with the matching symbol\n  const matchingStock = stockDataList.find(stock => stock.json.Symbol === aiSymbol);\n\n  // If a match is found, create the final object\n  if (matchingStock) {\n    finalResults.push({\n      json: {\n        \"Date\": formattedDate,\n        \"Symbol\": aiSymbol,\n        \"Shares price\": matchingStock.json[\"Current_Price\"],\n        \"Level of importance [0-10]\": aiItem.json.importance,\n        \"Trend 1D [%]\": matchingStock.json[\"Trend_1D [%]\"],\n        \"Trend 7D [%]\": matchingStock.json[\"Trend_7D [%]\"],\n        \"Trend 30D [%]\": matchingStock.json[\"Trend_30D [%]\"],\n        \"Trend 1Y [%]\": matchingStock.json[\"Trend_1Y [%]\"],\n        \"LLM description\": aiItem.json.description\n      }\n    });\n  }\n}\n\nreturn finalResults;"
      },
