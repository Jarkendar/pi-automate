    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "results = []\n\nfor item in _items:\n    try:\n        data = item['json']\n        if isinstance(data, list):\n            data = data[0]\n\n        result_data = data['chart']['result'][0]\n        symbol = result_data['meta']['symbol']\n        \n        raw_prices = result_data['indicators']['quote'][0]['close']\n        \n        clean_prices = [price for price in raw_prices if price is not None]\n        \n        if not clean_prices:\n            results.append({\"json\": {\"Symbol\": symbol, \"Error\": \"Brak danych cenowych\"}})\n            continue\n\n        current = clean_prices[-1]\n        \n        t1d = ((current - clean_prices[-2]) / clean_prices[-2] * 100) if len(clean_prices) >= 2 and clean_prices[-2] != 0 else 0\n        t7d = ((current - clean_prices[-6]) / clean_prices[-6] * 100) if len(clean_prices) >= 6 and clean_prices[-6] != 0 else 0\n        t30d = ((current - clean_prices[-22]) / clean_prices[-22] * 100) if len(clean_prices) >= 22 and clean_prices[-22] != 0 else 0\n        t1y = ((current - clean_prices[0]) / clean_prices[0] * 100) if len(clean_prices) >= 1 and clean_prices[0] != 0 else 0\n\n        results.append({\n            \"json\": {\n                \"Symbol\": symbol,\n                \"Current_Price\": round(current, 2),\n                \"Trend_1D [%]\": round(t1d, 2),\n                \"Trend_7D [%]\": round(t7d, 2),\n                \"Trend_30D [%]\": round(t30d, 2),\n                \"Trend_1Y [%]\": round(t1y, 2)\n            }\n        })\n        \n    except Exception as e:\n        results.append({\"json\": {\"Error\": str(e), \"Context\": \"Błąd parsowania danych Yahoo\"}})\n\nreturn results"
      },
